{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["namespace", "commonLabels", "podAnnotations", "imagePullSecrets", "app", "minio", "mc", "verdaccio", "ingress"],
  "properties": {
    "namespace": { "type": "string", "minLength": 1 },
    "commonLabels": { "type": "object", "additionalProperties": { "type": "string" } },
    "podAnnotations": { "type": "object", "additionalProperties": { "type": "string" } },
    "imagePullSecrets": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "app": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 }
      }
    },
    "minio": { "$ref": "#/definitions/minio" },
    "mc": { "$ref": "#/definitions/mc" },
    "verdaccio": { "$ref": "#/definitions/verdaccio" },
    "ingress": { "$ref": "#/definitions/ingress" }
  },
  "definitions": {
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "tag", "pullPolicy"],
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string", "minLength": 1 },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
      }
    },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requests", "limits"],
      "properties": {
        "requests": { "type": "object", "additionalProperties": { "type": "string" } },
        "limits": { "type": "object", "additionalProperties": { "type": "string" } }
      }
    },
    "probe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "initialDelaySeconds", "periodSeconds"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "initialDelaySeconds": { "type": "integer", "minimum": 0 },
        "periodSeconds": { "type": "integer", "minimum": 1 }
      }
    },
    "minio": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "replicaCount", "image", "port", "consolePort", "service", "secretName", "bucket", "persistence", "readinessProbe", "livenessProbe", "resources"],
      "properties": {
        "enabled": { "type": "boolean" },
        "replicaCount": { "type": "integer", "minimum": 0 },
        "image": { "$ref": "#/definitions/image" },
        "port": { "type": "integer", "minimum": 1 },
        "consolePort": { "type": "integer", "minimum": 1 },
        "service": {
          "type": "object",
          "additionalProperties": false,
          "required": ["port", "consolePort"],
          "properties": {
            "port": { "type": "integer", "minimum": 1 },
            "consolePort": { "type": "integer", "minimum": 1 }
          }
        },
        "secretName": { "type": "string", "minLength": 1 },
        "bucket": { "type": "string", "minLength": 1 },
        "persistence": {
          "type": "object",
          "additionalProperties": false,
          "required": ["size"],
          "properties": {
            "size": { "type": "string", "minLength": 1 }
          }
        },
        "readinessProbe": { "$ref": "#/definitions/probe" },
        "livenessProbe": { "$ref": "#/definitions/probe" },
        "resources": { "$ref": "#/definitions/resources" }
      }
    },
    "mc": {
      "type": "object",
      "additionalProperties": false,
      "required": ["image"],
      "properties": {
        "image": { "$ref": "#/definitions/image" }
      }
    },
    "verdaccio": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "replicaCount", "image", "port", "service", "secretName", "authSecretName", "auth", "s3", "readinessProbe", "livenessProbe", "resources"],
      "properties": {
        "enabled": { "type": "boolean" },
        "replicaCount": { "type": "integer", "minimum": 0 },
        "image": { "$ref": "#/definitions/image" },
        "port": { "type": "integer", "minimum": 1 },
        "service": {
          "type": "object",
          "additionalProperties": false,
          "required": ["port"],
          "properties": {
            "port": { "type": "integer", "minimum": 1 }
          }
        },
        "secretName": { "type": "string", "minLength": 1 },
        "authSecretName": { "type": "string", "minLength": 1 },
        "auth": {
          "type": "object",
          "additionalProperties": false,
          "required": ["maxUsers"],
          "properties": {
            "maxUsers": { "type": "integer", "minimum": -1 }
          }
        },
        "s3": {
          "type": "object",
          "additionalProperties": false,
          "required": ["envFromSecret", "ensureBucket", "bucket", "keyPrefix", "region", "endpoint", "forcePathStyle"],
          "properties": {
            "envFromSecret": { "type": "boolean" },
            "ensureBucket": { "type": "boolean" },
            "bucket": { "type": "string", "minLength": 1 },
            "keyPrefix": { "type": "string" },
            "region": { "type": "string", "minLength": 1 },
            "endpoint": { "type": "string", "minLength": 1 },
            "forcePathStyle": { "type": "boolean" }
          }
        },
        "readinessProbe": { "$ref": "#/definitions/probe" },
        "livenessProbe": { "$ref": "#/definitions/probe" },
        "resources": { "$ref": "#/definitions/resources" }
      }
    },
    "ingress": {
      "type": "object",
      "additionalProperties": false,
      "required": ["className", "host", "tls", "annotations"],
      "properties": {
        "className": { "type": "string", "minLength": 1 },
        "host": { "type": "string", "minLength": 1 },
        "tls": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "secretName"],
          "properties": {
            "enabled": { "type": "boolean" },
            "secretName": { "type": "string", "minLength": 1 }
          }
        },
        "annotations": { "type": "object", "additionalProperties": { "type": "string" } }
      }
    }
  }
}
