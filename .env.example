# Copy to `.env` before running helper scripts.
# `INFRA_SSH_PRIVATE_KEY_B64` must be a single-line base64-encoded private key.
INFRA_SSH_HOST=127.0.0.1
INFRA_SSH_USER=root
INFRA_SSH_PRIVATE_KEY_B64=
INFRA_KUBECONFIG_PATH=/etc/rancher/k3s/k3s.yaml
INFRA_KUBECTL_TUNNEL_LOCAL_PORT=56443
# Optional explicit tunnel namespace. Defaults to a hash of ssh user/host and tunnel ports.
# INFRA_KUBECTL_TUNNEL_NAMESPACE=
INFRA_SSH_CONTROL_PERSIST_SECONDS=600
# Usually leave unset; defaults to a namespace-scoped runtime socket.
# INFRA_SSH_CONTROL_SOCKET=/tmp/liberte-kube-ssh-custom.sock
